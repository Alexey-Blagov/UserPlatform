{
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/user-platform",
    "Audience": "api-gateway"
  },
  "ReverseProxy": {
    "Routes": {
      "profile-route": {
        "ClusterId": "profile-cluster",
        "Match": {
          "Path": "/api/profile/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "admin-route": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/api/admin/{**catch-all}"
        },
        "AuthorizationPolicy": "admin"
      }
    },
    "Clusters": {
      "profile-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://userprofileservice:8080/"
          }
        }
      },
      "admin-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://adminservice:8080/"
          }
        }
      }
    }
  }
}
