{
  "realm": "user-platform",
  "enabled": true,
  "roles": {
    "realm": [
      {
        "name": "user"
      },
      {
        "name": "admin"
      }
    ]
  },
  "clients": [
    {
      "clientId": "frontend-web",
      "name": "frontend-web",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5173/*"
      }
    },
    {
      "clientId": "api-gateway",
      "enabled": true,
      "publicClient": false,
      "secret": "gateway-secret",
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "user-profile-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "admin-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@example.com",
      "firstName": "Admin",
      "lastName": "User",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Admin123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "user"
      ]
    },
    {
      "username": "user",
      "enabled": true,
      "email": "user@example.com",
      "firstName": "Regular",
      "lastName": "User",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "User123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    }
  ]
}